/* ==================== 医生：任务管理 ==================== */
.doctor-task-page { min-height: 100vh; background: #f6f8fa; padding: 16px; padding-top: 20px; }
.dt-header { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 16px; padding: 0 4px; }
.dt-title { font-size: 20px; font-weight: 700; color: #2c3e50; }
.dt-count { font-size: 13px; color: #95a5a6; }
.dt-task-list { max-height: calc(100vh - 80px); }
.dt-task-card { background: #fff; border-radius: 14px; padding: 16px; margin-bottom: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.04); }
.dt-task-card:active { background: #f8f9fb; }
.dt-task-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; }
.dt-task-patient { font-size: 13px; color: #7f8c8d; font-weight: 600; }
.dt-task-status { font-size: 11px; padding: 3px 10px; border-radius: 10px; font-weight: 600; }
.dt-task-status.pending { background: #fff3e0; color: #ff9800; }
.dt-task-status.completed { background: #e8f5e9; color: #4caf50; }
.dt-task-title { font-size: 16px; font-weight: 600; color: #2c3e50; display: block; margin-bottom: 8px; }
.dt-task-bottom { display: flex; gap: 12px; }
.dt-task-angle, .dt-task-reps, .dt-task-deadline { font-size: 12px; color: #95a5a6; background: #f1f2f6; padding: 3px 8px; border-radius: 4px; }
.dt-empty { display: flex; flex-direction: column; align-items: center; padding: 80px 20px; }
.dt-empty-icon { font-size: 48px; margin-bottom: 12px; }
.dt-empty-text { font-size: 16px; font-weight: 600; color: #7f8c8d; }
.dt-empty-hint { font-size: 13px; color: #bdc3c7; margin-top: 6px; }

/* ==================== 患者：3D Canvas ==================== */
.gl-canvas { position: fixed; top: 0; left: 0; width: 100%; height: 100%; }
.status-overlay { position: absolute; top: 0; left: 0; right: 0; padding: 20px 16px 12px; display: flex; justify-content: space-between; align-items: center; background: #1a1a2e; }
.connection-badge { display: flex; align-items: center; padding: 6px 14px; border-radius: 16px; }
.connection-badge.online { background: #1a3a2e; color: #2ecc71; border: 1px solid #2ecc71; }
.connection-badge.offline { background: #3a1a1a; color: #e74c3c; border: 1px solid #e74c3c; }
.connection-badge.demo { background: #1a3a2e; color: #2ecc71; border: 1px solid #2ecc71; }
.badge-dot { width: 6px; height: 6px; border-radius: 50%; background: currentColor; margin-right: 6px; }
.badge-text { font-size: 12px; }
/* 输入源选择器 */
.source-selector { display: flex; align-items: center; gap: 4px; padding: 4px 12px; border-radius: 14px; background: #1a2a3e; color: #74b9ff; border: 1px solid #2980b9; }
.source-badge-text { font-size: 11px; font-weight: 600; }
.source-arrow { font-size: 9px; margin-left: 2px; }
.source-menu { position: absolute; top: 72px; right: 12px; background: #1a2a3e; border-radius: 12px; padding: 6px 0; border: 1px solid #2c3e50; z-index: 50; min-width: 140px; box-shadow: 0 4px 16px rgba(0,0,0,0.4); }
.source-option { padding: 10px 16px; font-size: 13px; color: #aab; text-align: left; white-space: nowrap; }
.source-option:active { background: rgba(255,255,255,0.1); }
.source-option.active { color: #74b9ff; font-weight: 700; background: rgba(116,185,255,0.15); }
.vital-row { display: flex; align-items: center; justify-content: center; margin-top: 8px; }
.vital-item { display: flex; flex-direction: column; align-items: center; min-width: 56px; }
.vital-num { font-size: 20px; font-weight: 700; line-height: 1; }
.vital-num.heart-color { color: #e74c3c; }
.vital-label { font-size: 9px; opacity: 0.45; margin-top: 2px; color: #ffffff; }
.angle-display { text-align: center; color: #ffffff; }
.angle-row { display: flex; align-items: center; justify-content: center; }
.angle-item { display: flex; flex-direction: column; align-items: center; min-width: 50px; }
.angle-divider { width: 1px; height: 32px; background: rgba(255,255,255,0.15); margin: 0 14px; }
.angle-num { font-size: 22px; font-weight: 700; display: block; line-height: 1; }
.angle-label { font-size: 10px; opacity: 0.5; margin-top: 2px; }
.muscle-popup { position: absolute; bottom: -300px; left: 16px; right: 16px; background: #14142a; border-radius: 20px; padding: 20px; border: 1px solid #333355; }
.muscle-popup.visible { bottom: 80px; }
.popup-header { display: flex; align-items: baseline; margin-bottom: 16px; }
.muscle-name { font-size: 20px; font-weight: 700; color: #ffffff; margin-right: 10px; }
.muscle-en { font-size: 12px; color: #888899; }
.popup-body { margin-bottom: 2px; }
.emg-row { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 12px; }
.emg-label { font-size: 13px; color: #888899; }
.emg-value { font-size: 22px; font-weight: 700; color: #ffffff; }
.activation-bar-bg { height: 6px; background: #2a2a3e; border-radius: 3px; margin-bottom: 8px; }
.activation-bar { height: 6px; border-radius: 3px; }
.activation-text { font-size: 12px; color: #888899; }
.popup-close { text-align: center; margin-top: 14px; padding: 10px 0 4px; color: #888899; font-size: 13px; border-top: 1px solid #2a2a3e; }
.reset-btn { position: absolute; bottom: 90px; right: 20px; width: 36px; height: 36px; background: rgba(255,255,255,0.08); border-radius: 50%; display: flex; justify-content: center; align-items: center; border: 1px solid rgba(255,255,255,0.15); }
.reset-icon { font-size: 18px; color: #cccccc; line-height: 1; }
.legend { position: absolute; bottom: 30px; left: 16px; right: 16px; display: flex; justify-content: center; }
.legend-item { display: flex; align-items: center; margin: 0 12px; }
.legend-text { font-size: 11px; color: #888899; }
.legend-dot { width: 8px; height: 8px; border-radius: 50%; margin-right: 6px; }

/* ==================== 训练浮层 ==================== */
.twin-training-bar {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(14, 14, 36, 0.94);
  border-radius: 22px 22px 0 0;
  padding: 18px 20px;
  padding-bottom: 30px;
  border-top: 1px solid rgba(255,255,255,0.08);
}

.ttb-top {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 10px;
}

.ttb-task-name {
  font-size: 16px;
  font-weight: 700;
  color: #ffffff;
  max-width: 55%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ttb-target {
  font-size: 11px;
  color: rgba(255,255,255,0.5);
}

/* 进度条 */
.ttb-progress-track {
  height: 4px;
  background: rgba(255,255,255,0.1);
  border-radius: 2px;
  margin-bottom: 14px;
  overflow: hidden;
}

.ttb-progress-fill {
  height: 4px;
  background: linear-gradient(90deg, #0984e3, #2ecc71);
  border-radius: 2px;
  transition: width 0.3s ease;
}

/* 数据行 */
.ttb-data-row {
  display: flex;
  justify-content: space-around;
  margin-bottom: 12px;
}

.ttb-data-item {
  text-align: center;
}

.ttb-data-num {
  font-size: 28px;
  font-weight: 700;
  color: #ffffff;
  line-height: 1;
  display: block;
  transition: color 0.3s ease;
}

.ttb-data-num.in-zone {
  color: #2ecc71;
}

.ttb-data-lbl {
  font-size: 10px;
  color: rgba(255,255,255,0.4);
  margin-top: 4px;
  display: block;
}

/* 角度区间可视化 */
.ttb-zone-bar {
  position: relative;
  height: 6px;
  background: rgba(255,255,255,0.08);
  border-radius: 3px;
  margin: 8px 0 16px;
  overflow: visible;
}

.ttb-zone-fill {
  position: absolute;
  top: 0;
  height: 6px;
  background: rgba(46, 204, 113, 0.35);
  border-radius: 3px;
  border: 1px solid rgba(46, 204, 113, 0.5);
  box-sizing: border-box;
}

.ttb-zone-dot {
  position: absolute;
  top: -5px;
  width: 16px;
  height: 16px;
  background: #ffffff;
  border: 2px solid #0984e3;
  border-radius: 50%;
  transform: translateX(-50%);
  transition: left 0.15s ease-out;
  z-index: 2;
  box-shadow: 0 0 10px rgba(9, 132, 227, 0.6);
}

.ttb-zone-dot.pulse {
  border-color: #2ecc71;
  box-shadow: 0 0 16px rgba(46, 204, 113, 0.8);
  animation: twin-dot-pulse 1.2s ease-in-out infinite;
}

@keyframes twin-dot-pulse {
  0%, 100% { box-shadow: 0 0 8px rgba(46,204,113,0.5); }
  50% { box-shadow: 0 0 20px rgba(46,204,113,0.9); }
}

/* 按钮 */
.ttb-btns {
  text-align: center;
}

.ttb-start-btn, .ttb-stop-btn {
  display: inline-block;
  padding: 10px 40px;
  border-radius: 22px;
  font-size: 15px;
  font-weight: 600;
}

.ttb-start-btn {
  background: linear-gradient(135deg, #2ecc71, #27ae60);
  color: #fff;
}

.ttb-start-btn:active {
  opacity: 0.8;
}

.ttb-stop-btn {
  background: rgba(255,255,255,0.1);
  color: rgba(255,255,255,0.7);
}

/* Guidance text */
.ttb-guidance {
  text-align: center;
  padding: 8px 16px;
  margin-bottom: 10px;
  background: rgba(255,255,255,0.06);
  border-radius: 12px;
  border-left: 3px solid transparent;
  transition: all 0.3s;
}

.ttb-guidance.good {
  background: rgba(46,204,113,0.12);
  border-left-color: #2ecc71;
}

.ttb-guidance.hint {
  background: rgba(241,196,15,0.08);
  border-left-color: #f1c40f;
}

.ttb-guidance.warn {
  background: rgba(231,76,60,0.1);
  border-left-color: #e74c3c;
}

.ttb-guidance-text {
  font-size: 15px;
  font-weight: 600;
  color: rgba(255,255,255,0.7);
}

.ttb-guidance.good .ttb-guidance-text { color: #2ecc71; }
.ttb-guidance.hint .ttb-guidance-text { color: #f1c40f; }
.ttb-guidance.warn .ttb-guidance-text { color: #e74c3c; }

/* Doctor: record button */
.dt-header-actions {
  display: flex;
  align-items: center;
  gap: 10px;
}

.dt-record-btn {
  background: linear-gradient(135deg, #e74c3c, #c0392b) !important;
  color: #fff !important;
  border-radius: 14px !important;
  font-size: 12px !important;
  border: none !important;
}
