/* pages/patientDetail/patientDetail.wxss */
.page {
  min-height: 100vh;
  background: #f6f8fa;
  padding-bottom: 30px;
}

/* 患者头 */
.patient-header {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #0984e3, #00a8ff);
  padding: 24px 20px;
  color: #fff;
  gap: 14px;
}

.ph-avatar {
  width: 52px;
  height: 52px;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.25);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22px;
  font-weight: 700;
  flex-shrink: 0;
}

.ph-info {
  flex: 1;
}

.ph-name {
  font-size: 20px;
  font-weight: 700;
}

.ph-stats {
  display: flex;
  gap: 8px;
  margin-top: 4px;
}

.ph-stat {
  font-size: 12px;
  opacity: 0.85;
  background: rgba(255, 255, 255, 0.2);
  padding: 2px 8px;
  border-radius: 10px;
}

.ph-online {
  display: flex;
  align-items: center;
  gap: 4px;
  margin-top: 4px;
  font-size: 11px;
}

.online-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
}

.online-dot.live { background: #2ecc71; }
.online-dot.off { background: #f1c40f; }

.publish-task-btn {
  background: rgba(255, 255, 255, 0.25) !important;
  color: #fff !important;
  border-radius: 16px !important;
  font-size: 12px;
  flex-shrink: 0;
}

/* Tab */
.detail-tabs {
  display: flex;
  background: #fff;
  border-bottom: 1px solid #f1f2f6;
}

.dtab {
  flex: 1;
  text-align: center;
  padding: 14px 0;
  font-size: 15px;
  color: #95a5a6;
  border-bottom: 2px solid transparent;
}

.dtab.active {
  color: #0984e3;
  border-bottom-color: #0984e3;
  font-weight: 600;
}

/* 内容区 */
.detail-body {
  padding: 12px 16px;
  min-height: 300px;
}

.empty-state {
  padding: 80px 20px;
  text-align: center;
}

.empty-icon {
  font-size: 48px;
  display: block;
  margin-bottom: 12px;
}

.empty-text {
  font-size: 15px;
  color: #bdc3c7;
  display: block;
}

.empty-hint {
  font-size: 13px;
  color: #dcdde1;
  display: block;
  margin-top: 6px;
}

/* 记录卡片 */
.record-item {
  display: flex;
  background: #fff;
  padding: 15px;
  border-radius: 14px;
  margin-bottom: 10px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.03);
}

.item-left { flex: 1; }

.mode-tag {
  display: inline-block;
  font-size: 10px;
  padding: 2px 8px;
  border-radius: 4px;
  font-weight: bold;
}

.tag-sport { background: #fff2e6; color: #ff9f43; }
.tag-rehab { background: #e3f2fd; color: #00a8ff; }

.date-text {
  font-size: 12px;
  color: #a4b0be;
  margin-left: 8px;
}

.data-grid {
  display: flex;
  gap: 15px;
  margin-top: 8px;
}

.data-cell { display: flex; flex-direction: column; }
.data-cell .l { font-size: 10px; color: #999; }
.data-cell .v { font-size: 16px; font-weight: bold; color: #2c3e50; }

/* 任务卡片 */
.task-item {
  display: flex;
  justify-content: space-between;
  background: #fff;
  padding: 14px 16px;
  border-radius: 14px;
  margin-bottom: 10px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.03);
}

.task-left { flex: 1; }
.task-title { font-size: 15px; font-weight: 600; color: #2c3e50; display: block; }
.task-desc { font-size: 12px; color: #95a5a6; display: block; margin-top: 4px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

.task-meta-row { display: flex; gap: 6px; margin-top: 6px; }
.task-meta-tag { font-size: 10px; color: #7f8c8d; background: #f1f2f6; padding: 2px 8px; border-radius: 4px; }

.task-right { text-align: right; }
.task-status { font-size: 11px; padding: 3px 8px; border-radius: 10px; font-weight: 600; display: inline-block; }
.task-status.pending { background: #fff3e0; color: #ff9800; }
.task-status.completed { background: #e8f5e9; color: #4caf50; }

.task-date { font-size: 11px; color: #bdc3c7; display: block; margin-top: 4px; }
