/* ================= Full-screen Page ================= */
.page {
  min-height: 100vh;
  background: linear-gradient(160deg, #f0f4ff 0%, #e8f0fe 40%, #f5f0ff 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40px 20px 30px;
  box-sizing: border-box;
}

/* ================= Hero ================= */
.hero {
  text-align: center;
  margin-bottom: 30px;
}

.logo-area {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  margin-bottom: 30px;
}

.logo-icon {
  font-size: 40px;
}

.app-name {
  font-size: 22px;
  font-weight: 700;
  color: #2c3e50;
}

.title {
  font-size: 26px;
  font-weight: 700;
  color: #1a1a2e;
  margin-bottom: 8px;
}

.subtitle {
  font-size: 14px;
  color: #7f8c8d;
  max-width: 280px;
  line-height: 1.5;
}

/* ================= Role Cards ================= */
.role-cards {
  width: 100%;
  max-width: 360px;
  display: flex;
  flex-direction: column;
  gap: 16px;
  margin-bottom: 40px;
}

.role-card {
  position: relative;
  background: #ffffff;
  border-radius: 20px;
  padding: 24px 20px;
  border: 3px solid transparent;
  box-shadow: 0 4px 16px rgba(0, 0, 0, 0.06);
  transition: all 0.25s ease;
}

.role-card:active {
  transform: scale(0.97);
}

.role-card.selected-doctor {
  border-color: #0984e3;
  background: #f0f7ff;
  box-shadow: 0 4px 20px rgba(9, 132, 227, 0.15);
}

.role-card.selected-patient {
  border-color: #00b894;
  background: #f0fff8;
  box-shadow: 0 4px 20px rgba(0, 184, 148, 0.15);
}

.card-icon {
  font-size: 36px;
  margin-bottom: 10px;
}

.card-title {
  font-size: 20px;
  font-weight: 700;
  color: #2c3e50;
  margin-bottom: 6px;
}

.card-desc {
  font-size: 13px;
  color: #95a5a6;
  line-height: 1.5;
}

.check-mark {
  position: absolute;
  top: 16px;
  right: 16px;
  width: 28px;
  height: 28px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
  font-weight: bold;
  color: #fff;
}

.selected-doctor .check-mark {
  background: #0984e3;
}

.selected-patient .check-mark {
  background: #00b894;
}

/* ================= Action ================= */
.action-area {
  width: 100%;
  max-width: 360px;
}

.confirm-btn {
  width: 100%;
  height: 52px;
  border-radius: 26px;
  font-size: 17px;
  font-weight: 700;
  background: #dcdde1;
  color: #a4b0be;
  border: none;
  transition: all 0.25s ease;
}

.confirm-btn.active {
  background: linear-gradient(135deg, #0984e3 0%, #00a8ff 100%);
  color: #fff;
  box-shadow: 0 6px 20px rgba(9, 132, 227, 0.3);
}

.confirm-btn.active:active {
  transform: scale(0.96);
  opacity: 0.9;
}
