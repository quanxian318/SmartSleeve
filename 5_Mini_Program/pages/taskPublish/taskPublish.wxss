.pg { min-height: 100vh; background: #f2f2f7; padding: 0 0 120px; }

.sec { background: #fff; margin: 0 0 12px; padding: 20px; }
.sec-t { font-size: 13px; color: #8e8e93; letter-spacing: 0.5px; display: block; margin-bottom: 14px; }

/* Picker */
.pick-row { white-space: nowrap; }
.pick { display: inline-flex; flex-direction: column; align-items: center; width: 78px; margin-right: 16px; padding: 14px 8px; border-radius: 16px; background: #f2f2f7; }
.pick.on { background: #007aff; }
.pick-f { width: 44px; height: 44px; border-radius: 50%; background: #e5e5ea; display: flex; align-items: center; justify-content: center; font-size: 19px; font-weight: 700; color: #8e8e93; margin-bottom: 6px; }
.pick.on .pick-f { background: rgba(255,255,255,0.25); color: #fff; }
.pick-n { font-size: 12px; color: #3a3a3c; max-width: 68px; overflow: hidden; text-overflow: ellipsis; }
.pick.on .pick-n { color: #fff; }
.hint { font-size: 14px; color: #aeaeb2; padding: 16px 0; text-align: center; }

/* Inputs */
.inp { width: 100%; height: 48px; font-size: 18px; font-weight: 600; border: none; border-bottom: 1px solid #e5e5ea; padding: 0; box-sizing: border-box; color: #000; }
.inp::placeholder { color: #c7c7cc; font-weight: 400; }
.area { width: 100%; height: 64px; font-size: 15px; border: none; padding: 12px 0 0; box-sizing: border-box; color: #3a3a3c; line-height: 1.5; }

/* Range bar */
.range-bar { margin-bottom: 16px; }
.range-track { height: 6px; background: #e5e5ea; border-radius: 3px; position: relative; margin-bottom: 6px; }
.range-fill { height: 6px; background: #007aff; border-radius: 3px; position: absolute; top: 0; }
.range-lbl { display: flex; justify-content: space-between; font-size: 10px; color: #aeaeb2; }

/* Steppers */
.row { display: flex; gap: 16px; }
.col { flex: 1; }
.lbl { font-size: 12px; color: #8e8e93; display: block; margin-bottom: 8px; }
.step { display: flex; align-items: center; justify-content: center; background: #f2f2f7; border-radius: 12px; overflow: hidden; }
.step-b { width: 44px; height: 44px; display: flex; align-items: center; justify-content: center; font-size: 20px; color: #007aff; font-weight: 500; }
.step-b:active { background: rgba(0,122,255,0.1); }
.step-v { font-size: 16px; font-weight: 600; color: #000; min-width: 44px; text-align: center; }
.date { height: 44px; display: flex; align-items: center; justify-content: center; background: #f2f2f7; border-radius: 12px; font-size: 14px; color: #007aff; font-weight: 500; }

/* Preview */
.preview { background: #1c1c1e; border-radius: 16px; padding: 18px; color: #fff; }
.pv-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; }
.pv-t { font-size: 17px; font-weight: 700; }
.pv-b { font-size: 10px; padding: 3px 10px; border-radius: 10px; background: rgba(255,149,0,0.2); color: #ff9500; }
.pv-d { font-size: 13px; opacity: 0.55; line-height: 1.5; margin-bottom: 12px; display: block; }
.pv-tags { display: flex; gap: 8px; font-size: 12px; opacity: 0.6; }

/* Bottom */
.bot { position: fixed; bottom: 0; left: 0; right: 0; padding: 12px 20px 32px; background: #fff; border-top: 1px solid #f0f0f0; }
.btn { width: 100%; height: 52px; background: #007aff; color: #fff; border-radius: 14px; font-size: 17px; font-weight: 600; border: none; }
.btn:active { opacity: 0.85; }

/* Template selector */
.tpl-header { display: flex; justify-content: space-between; align-items: center; cursor: pointer; }
.tpl-arrow { font-size: 12px; color: #8e8e93; }

.tpl-picked { position: relative; display: flex; align-items: center; gap: 8px; margin-top: 10px; padding: 12px; background: #e3f2fd; border-radius: 12px; }
.tpl-picked-name { font-size: 14px; font-weight: 600; color: #0984e3; }
.tpl-picked-info { font-size: 11px; color: #7f8c8d; }
.tpl-clear { position: absolute; right: 12px; font-size: 16px; color: #95a5a6; padding: 4px; }

.tpl-list { margin-top: 10px; }
.tpl-card { background: #fff; border-radius: 12px; padding: 12px 14px; margin-bottom: 8px; border: 1px solid #e5e5ea; }
.tpl-card.picked { border-color: #0984e3; background: #f0f7ff; }
.tpl-card:active { background: #f8f9fb; }
.tpl-card-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 4px; }
.tpl-card-name { font-size: 14px; font-weight: 600; color: #2c3e50; }
.tpl-card-type { font-size: 10px; color: #95a5a6; background: #f1f2f6; padding: 2px 8px; border-radius: 4px; }
.tpl-card-tags { display: flex; gap: 8px; font-size: 11px; color: #7f8c8d; }

.tpl-empty { text-align: center; padding: 16px 0; font-size: 13px; color: #bdc3c7; }
.tpl-empty-hint { font-size: 11px; display: block; margin-top: 4px; }
